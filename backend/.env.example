# ── MWS API ────────────────────────────────────────────
MWS_BASE_URL=https://api.gpt.mws.ru
MWS_API_KEY=your_mws_api_key_here

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5433/mirea

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Ollama (Router) ─────────────────────────────────────
ROUTER_URL=http://localhost:11434
ROUTER_MODEL=qwen2.5:3b

# ── Media services ──────────────────────────────────────
ASR_URL=http://localhost:8001
IMAGE_GEN_URL=http://localhost:8002
VLM_URL=http://localhost:8003

# ── TTS ─────────────────────────────────────────────────
TTS_VOICE=ru-RU-SvetlanaNeural

# ── Limits ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
MAX_FILE_SIZE_MB=50
