# ── MWS API ──────────────────────────────────────────────────────
MWS_BASE_URL=https://api.gpt.mws.ru
MWS_API_KEY=your_api_key_here

# ── Models ───────────────────────────────────────────────────────
MODEL_TEXT=mws-gpt-alpha
MODEL_CODE=kodify-2.0
MODEL_LONG=cotype-preview-32k
MODEL_EMBED=bge-m3

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/mirea

# ── Cache ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Local LLM (роутер) ───────────────────────────────────────────
ROUTER_URL=http://ollama:11434
ROUTER_MODEL=qwen2.5:3b

# ── Media сервисы ────────────────────────────────────────────────
ASR_URL=http://localhost:8001
TTS_VOICE=ru-RU-SvetlanaNeural
IMAGE_GEN_URL=http://localhost:8002
VLM_URL=http://localhost:8003

# ── Лимиты ───────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
MAX_FILE_SIZE_MB=50
CONTEXT_MAX_TOKENS=8000
